  "design_decisions": {
    "animation_method_rationale": "Characters use DragonBones skeletal animation for expressive idle and emotional reactions without large sprite sheet memory cost. Tile icons are static PNG with VFX-only match effects to keep atlas size minimal. Special blocks use 12-frame frame animation per unique activation. UI uses Cocos tween for all spring/scale transitions. VFX are particle-only (no separate sprite sheets) with atlas strip frames only for lighthouse and restoration effects.",
    "tile_count_decision": "20 total tile patterns (12 unlocked Ch1, +2-3 per chapter). Matches core-mechanics.json board_design.tile_types.count=20.",
    "special_block_count_decision": "5 special block types: wave, light_chain, pierce, swap, cascade — exactly matching core-mechanics.json special_tiles array. light_chain replaces 'chain' from concept doc to match the actual design (v4.0 revision).",
    "chapter_count": 6,
    "npc_count_decision": "5 named NPCs (Kenzo, Umeko, Naho, Fuyuko, Chairman) + 1 protagonist (Ritsu) + 1 romantic interest (Hinata) = 7 total skeletal characters. character.npc_count=5 covers named NPCs only; total_skeletal_characters=7.",
    "image_gen_api_selection": "google-imagen-4 as primary for high quality watercolor/painterly 2D output matching hand-drawn-watercolor style keyword; openrouter-gpt-image as fallback/secondary for style variation and batch diversity.",
    "atlas_per_chapter_rationale": "Web-canvas-2d platform requires careful memory management; per-chapter atlas allows progressive loading as player advances, keeping active VRAM footprint small. Special blocks atlas is global since all 5 types may appear across chapters.",
    "vfx_particle_budget_200": "200 particles per combo burst is sufficient for healing aesthetic without the 'excessive particle debris' prohibited style. Matches the 4-6 particles per tile guideline in art-style-guide.json animation_direction.combo_vfx."
  }
