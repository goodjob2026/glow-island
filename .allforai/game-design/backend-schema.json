{
  "meta": {
    "created_at": "2026-05-07T00:00:00.000Z",
    "product": "Glow Island",
    "version": "1.0",
    "description": "PostgreSQL数据库Schema — DDL格式 + Prisma模型格式",
    "database": "PostgreSQL 15+",
    "orm": "Prisma 5.x"
  },
  "ddl": {
    "description": "PostgreSQL DDL，可直接执行",
    "statements": [
      "-- ============================================================",
      "-- Glow Island — PostgreSQL Schema",
      "-- ============================================================",
      "",
      "CREATE EXTENSION IF NOT EXISTS \"uuid-ossp\";",
      "",
      "-- ------------------------------------------------------------",
      "-- players: 玩家基础身份表（匿名设备绑定）",
      "-- ------------------------------------------------------------",
      "CREATE TABLE players (",
      "  id            UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),",
      "  device_id     TEXT        NOT NULL UNIQUE,",
      "  platform      TEXT        NOT NULL CHECK (platform IN ('ios', 'android', 'taptap')),",
      "  created_at    TIMESTAMPTZ NOT NULL DEFAULT NOW(),",
      "  updated_at    TIMESTAMPTZ NOT NULL DEFAULT NOW()",
      ");",
      "",
      "CREATE INDEX idx_players_device_id ON players(device_id);",
      "",
      "-- ------------------------------------------------------------",
      "-- player_saves: 玩家存档（JSONB，单行存全量状态）",
      "-- ------------------------------------------------------------",
      "CREATE TABLE player_saves (",
      "  id                UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),",
      "  player_id         UUID        NOT NULL REFERENCES players(id) ON DELETE CASCADE,",
      "  chapter_progress  JSONB       NOT NULL DEFAULT '{}',",
      "  currency          JSONB       NOT NULL DEFAULT '{\"beach_coins\": 200, \"glowstone\": 0}',",
      "  materials         JSONB       NOT NULL DEFAULT '{\"driftwood\": 0, \"tropical_flower\": 0, \"coral_fragment\": 0, \"starfish\": 0, \"ancient_tile\": 0, \"moonlight_crystal\": 0}',",
      "  boosters          JSONB       NOT NULL DEFAULT '{}',",
      "  decorations       JSONB       NOT NULL DEFAULT '{}',",
      "  monthly_card      JSONB       NOT NULL DEFAULT '{\"active\": false, \"expires_at\": null, \"last_claimed_date\": null}',",
      "  settings          JSONB       NOT NULL DEFAULT '{\"sfx\": true, \"music\": true, \"notifications\": true}',",
      "  client_version    TEXT,",
      "  checksum          TEXT,",
      "  updated_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),",
      "  CONSTRAINT uq_player_save UNIQUE(player_id)",
      ");",
      "",
      "CREATE INDEX idx_player_saves_player_id ON player_saves(player_id);",
      "CREATE INDEX idx_player_saves_updated_at ON player_saves(updated_at);",
      "",
      "COMMENT ON COLUMN player_saves.chapter_progress IS",
      "  'Schema: {\"1\": {\"status\": \"completed\", \"stars\": 3, \"highest_level\": 10, \"materials_earned\": 120}}';",
      "COMMENT ON COLUMN player_saves.currency IS",
      "  'Schema: {\"beach_coins\": 200, \"glowstone\": 0}';",
      "COMMENT ON COLUMN player_saves.materials IS",
      "  'Schema: {\"driftwood\": 0, ..., \"moonlight_crystal\": 0}';",
      "COMMENT ON COLUMN player_saves.boosters IS",
      "  'Schema: {\"rainbow_block\": 2, \"bomb_block\": 1, \"extra_steps_3\": 0}';",
      "COMMENT ON COLUMN player_saves.decorations IS",
      "  'Schema: {\"decoration_id\": true, ...}  — owned decoration IDs set';",
      "",
      "-- ------------------------------------------------------------",
      "-- leaderboard_entries: 全球排行榜",
      "-- ------------------------------------------------------------",
      "CREATE TABLE leaderboard_entries (",
      "  id              UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),",
      "  player_id       UUID        NOT NULL REFERENCES players(id) ON DELETE CASCADE,",
      "  display_name    TEXT        NOT NULL CHECK (char_length(display_name) BETWEEN 1 AND 20),",
      "  total_score     BIGINT      NOT NULL DEFAULT 0,",
      "  chapter_reached SMALLINT    NOT NULL DEFAULT 1 CHECK (chapter_reached BETWEEN 1 AND 6),",
      "  highest_level   INT         NOT NULL DEFAULT 1,",
      "  updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),",
      "  CONSTRAINT uq_leaderboard_player UNIQUE(player_id)",
      ");",
      "",
      "CREATE INDEX idx_leaderboard_score ON leaderboard_entries(total_score DESC, updated_at DESC);",
      "CREATE INDEX idx_leaderboard_chapter ON leaderboard_entries(chapter_reached DESC, total_score DESC);",
      "",
      "-- ------------------------------------------------------------",
      "-- iap_transactions: IAP收据记录与验证状态",
      "-- ------------------------------------------------------------",
      "CREATE TABLE iap_transactions (",
      "  id              UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),",
      "  player_id       UUID        NOT NULL REFERENCES players(id) ON DELETE RESTRICT,",
      "  product_id      TEXT        NOT NULL,",
      "  sku_id          TEXT        NOT NULL,",
      "  platform        TEXT        NOT NULL CHECK (platform IN ('ios', 'android', 'taptap')),",
      "  receipt_data    TEXT        NOT NULL,",
      "  transaction_id  TEXT        UNIQUE,",
      "  amount_cents    INT         NOT NULL CHECK (amount_cents >= 0),",
      "  currency_code   TEXT        NOT NULL DEFAULT 'CNY',",
      "  status          TEXT        NOT NULL DEFAULT 'pending'",
      "                              CHECK (status IN ('pending', 'verified', 'failed', 'refunded', 'duplicate')),",
      "  glowstone_granted  INT      DEFAULT 0,",
      "  items_granted   JSONB       DEFAULT '[]',",
      "  verified_at     TIMESTAMPTZ,",
      "  created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),",
      "  updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW()",
      ");",
      "",
      "CREATE INDEX idx_iap_player_id ON iap_transactions(player_id);",
      "CREATE INDEX idx_iap_status ON iap_transactions(status);",
      "CREATE INDEX idx_iap_created_at ON iap_transactions(created_at DESC);",
      "CREATE INDEX idx_iap_transaction_id ON iap_transactions(transaction_id) WHERE transaction_id IS NOT NULL;",
      "",
      "-- ------------------------------------------------------------",
      "-- player_daily_rewards: 每日签到状态（月卡丹青石领取记录）",
      "-- ------------------------------------------------------------",
      "CREATE TABLE player_daily_rewards (",
      "  id              UUID        PRIMARY KEY DEFAULT uuid_generate_v4(),",
      "  player_id       UUID        NOT NULL REFERENCES players(id) ON DELETE CASCADE,",
      "  reward_date     DATE        NOT NULL,",
      "  reward_type     TEXT        NOT NULL CHECK (reward_type IN ('login_streak', 'monthly_card', 'task')),",
      "  beach_coins     INT         NOT NULL DEFAULT 0,",
      "  glowstone       INT         NOT NULL DEFAULT 0,",
      "  created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),",
      "  CONSTRAINT uq_player_daily_reward UNIQUE(player_id, reward_date, reward_type)",
      ");",
      "",
      "CREATE INDEX idx_daily_rewards_player_date ON player_daily_rewards(player_id, reward_date DESC);",
      "",
      "-- ------------------------------------------------------------",
      "-- Trigger: auto-update updated_at columns",
      "-- ------------------------------------------------------------",
      "CREATE OR REPLACE FUNCTION update_updated_at_column()",
      "RETURNS TRIGGER AS $$",
      "BEGIN",
      "  NEW.updated_at = NOW();",
      "  RETURN NEW;",
      "END;",
      "$$ language 'plpgsql';",
      "",
      "CREATE TRIGGER trg_players_updated_at",
      "  BEFORE UPDATE ON players",
      "  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();",
      "",
      "CREATE TRIGGER trg_player_saves_updated_at",
      "  BEFORE UPDATE ON player_saves",
      "  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();",
      "",
      "CREATE TRIGGER trg_leaderboard_updated_at",
      "  BEFORE UPDATE ON leaderboard_entries",
      "  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();",
      "",
      "CREATE TRIGGER trg_iap_updated_at",
      "  BEFORE UPDATE ON iap_transactions",
      "  FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();"
    ]
  },
  "prisma_schema": {
    "description": "Prisma Schema（schema.prisma），对应上述PostgreSQL DDL",
    "datasource": {
      "provider": "postgresql",
      "url": "env(\"DATABASE_URL\")"
    },
    "generator": {
      "provider": "prisma-client-js"
    },
    "models_raw": [
      "// ============================================================",
      "// Glow Island — Prisma Schema",
      "// ============================================================",
      "",
      "generator client {",
      "  provider = \"prisma-client-js\"",
      "}",
      "",
      "datasource db {",
      "  provider = \"postgresql\"",
      "  url      = env(\"DATABASE_URL\")",
      "}",
      "",
      "model Player {",
      "  id          String   @id @default(uuid()) @db.Uuid",
      "  deviceId    String   @unique @map(\"device_id\")",
      "  platform    String",
      "  createdAt   DateTime @default(now()) @map(\"created_at\")",
      "  updatedAt   DateTime @updatedAt @map(\"updated_at\")",
      "",
      "  save              PlayerSave?",
      "  leaderboardEntry  LeaderboardEntry?",
      "  iapTransactions   IapTransaction[]",
      "  dailyRewards      PlayerDailyReward[]",
      "",
      "  @@map(\"players\")",
      "}",
      "",
      "model PlayerSave {",
      "  id              String   @id @default(uuid()) @db.Uuid",
      "  playerId        String   @unique @map(\"player_id\") @db.Uuid",
      "  chapterProgress Json     @default(\"{}\") @map(\"chapter_progress\")",
      "  currency        Json     @default(\"{\\\"beach_coins\\\": 200, \\\"glowstone\\\": 0}\") @map(\"currency\")",
      "  materials       Json     @default(\"{}\") @map(\"materials\")",
      "  boosters        Json     @default(\"{}\") @map(\"boosters\")",
      "  decorations     Json     @default(\"{}\") @map(\"decorations\")",
      "  monthlyCard     Json     @default(\"{\\\"active\\\": false, \\\"expires_at\\\": null, \\\"last_claimed_date\\\": null}\") @map(\"monthly_card\")",
      "  settings        Json     @default(\"{\\\"sfx\\\": true, \\\"music\\\": true, \\\"notifications\\\": true}\") @map(\"settings\")",
      "  clientVersion   String?  @map(\"client_version\")",
      "  checksum        String?",
      "  updatedAt       DateTime @updatedAt @map(\"updated_at\")",
      "",
      "  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)",
      "",
      "  @@map(\"player_saves\")",
      "}",
      "",
      "model LeaderboardEntry {",
      "  id             String   @id @default(uuid()) @db.Uuid",
      "  playerId       String   @unique @map(\"player_id\") @db.Uuid",
      "  displayName    String   @map(\"display_name\")",
      "  totalScore     BigInt   @default(0) @map(\"total_score\")",
      "  chapterReached Int      @default(1) @map(\"chapter_reached\")",
      "  highestLevel   Int      @default(1) @map(\"highest_level\")",
      "  updatedAt      DateTime @updatedAt @map(\"updated_at\")",
      "",
      "  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)",
      "",
      "  @@map(\"leaderboard_entries\")",
      "}",
      "",
      "model IapTransaction {",
      "  id               String    @id @default(uuid()) @db.Uuid",
      "  playerId         String    @map(\"player_id\") @db.Uuid",
      "  productId        String    @map(\"product_id\")",
      "  skuId            String    @map(\"sku_id\")",
      "  platform         String",
      "  receiptData      String    @map(\"receipt_data\")",
      "  transactionId    String?   @unique @map(\"transaction_id\")",
      "  amountCents      Int       @map(\"amount_cents\")",
      "  currencyCode     String    @default(\"CNY\") @map(\"currency_code\")",
      "  status           String    @default(\"pending\")",
      "  glowstoneGranted Int       @default(0) @map(\"glowstone_granted\")",
      "  itemsGranted     Json      @default(\"[]\") @map(\"items_granted\")",
      "  verifiedAt       DateTime? @map(\"verified_at\")",
      "  createdAt        DateTime  @default(now()) @map(\"created_at\")",
      "  updatedAt        DateTime  @updatedAt @map(\"updated_at\")",
      "",
      "  player Player @relation(fields: [playerId], references: [id], onDelete: Restrict)",
      "",
      "  @@map(\"iap_transactions\")",
      "}",
      "",
      "model PlayerDailyReward {",
      "  id          String   @id @default(uuid()) @db.Uuid",
      "  playerId    String   @map(\"player_id\") @db.Uuid",
      "  rewardDate  DateTime @map(\"reward_date\") @db.Date",
      "  rewardType  String   @map(\"reward_type\")",
      "  beachCoins  Int      @default(0) @map(\"beach_coins\")",
      "  glowstone   Int      @default(0) @map(\"glowstone\")",
      "  createdAt   DateTime @default(now()) @map(\"created_at\")",
      "",
      "  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)",
      "",
      "  @@unique([playerId, rewardDate, rewardType])",
      "  @@map(\"player_daily_rewards\")",
      "}"
    ]
  },
  "jsonb_schemas": {
    "chapter_progress": {
      "description": "player_saves.chapter_progress 的JSONB结构",
      "example": {
        "1": {
          "status": "completed",
