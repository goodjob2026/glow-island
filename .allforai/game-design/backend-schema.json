        "ancient_tile": 0,
        "moonlight_crystal": 0
      }
    },
    "monthly_card": {
      "description": "player_saves.monthly_card 的JSONB结构",
      "example": {
        "active": true,
        "expires_at": "2026-06-07T00:00:00.000Z",
        "purchased_at": "2026-05-07T00:00:00.000Z",
        "last_claimed_date": "2026-05-07",
        "days_claimed": 1,
        "transaction_id": "uuid-of-iap-transaction"
      }
    }
  },
  "migration_notes": {
    "initial_migration": "运行 prisma migrate dev --name init 创建所有表",
    "seed_data": "新玩家 player_saves 默认值由数据库DEFAULT子句保证，无需Seed脚本",
    "indexes": "关键查询路径均有索引覆盖：device_id查找、leaderboard排序、iap状态查询",
    "soft_delete": "players/player_saves不做软删除（治愈游戏，无竞技数据敏感性），iap_transactions使用status字段标记退款",
    "backup_strategy": "建议每日全量备份 + WAL流复制，iap_transactions为关键业务数据需单独备份策略"
  }
}
