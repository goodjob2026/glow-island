  "special_blocks": [
    {
      "id": "bomb",
      "name": "炸弹",
      "name_en": "Bomb",
      "trigger": "3连击必定生成 / 关卡JSON预置",
      "effect": "消除以炸弹块为中心的 3×3 范围内所有图块（含障碍物及覆盖层）",
      "effect_range": { "shape": "square", "radius": 1, "size": "3x3" },
      "animation_duration_s": 0.5,
      "skippable": false,
      "spawn_on_combo": 3
    },
    {
      "id": "windmill",
      "name": "风车",
      "name_en": "Windmill",
      "trigger": "4连击必定生成 / 关卡JSON预置",
      "effect": "清除风车块所在整行+整列（十字清除，行消和列消同时触发）",
      "effect_range": { "shape": "cross", "span": "full_row_and_column" },
      "animation_duration_s": 0.4,
      "skippable": false,
      "spawn_on_combo": 4
    },
    {
      "id": "lantern",
      "name": "灯光",
      "name_en": "Lantern",
      "trigger": "仅关卡JSON预置（不可通过连击生成）",
      "effect": "自动寻路连接距离最近的同类型图块并消除双方；无目标时持续脉冲等待",
      "effect_range": { "shape": "auto", "target": "nearest_same_type", "max_search_radius": null },
      "animation_duration_s": 0.3,
      "skippable": false,
      "spawn_on_combo": null
    },
    {
      "id": "wave",
      "name": "海浪",
      "name_en": "Wave",
      "trigger": "仅关卡JSON预置（不可通过连击生成）",
      "effect": "重新随机排列棋盘上所有图块位置（保持各类型图块数量不变），最多3次自动重排",
      "effect_range": { "shape": "full_board", "preserves_type_counts": true, "max_auto_retry": 3 },
      "animation_duration_s": 0.8,
      "skippable": false,
      "spawn_on_combo": null
    }
  ],

