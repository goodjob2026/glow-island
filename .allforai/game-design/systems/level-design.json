  "encounter_placement": {
    "overview": "Glow Island无传统战斗遭遇，『遭遇』对应关卡内的障碍/特殊图块首次出现时机与密度规划",
    "principles": [
      "新机制首次出现：单一障碍 + 宽裕步数 + 清晰视觉提示",
      "组合遭遇：至多2种新障碍同时出现，分别保持可读性",
      "Boss关（每章第30关）：当章全部障碍和特殊图块综合登场，步数压缩15%",
      "禅境关：关闭步数上限，移除所有高难度障碍，纯粹连击爽快感"
    ],
    "obstacle_density_by_difficulty": {
      "easy_breather": "障碍数量 ≤ 2个，类型 ≤ 1种，步数余量 ≥ 40%",
      "standard": "障碍数量 3-5个，类型 1-2种，步数余量 20-35%",
      "challenge": "障碍数量 5-8个，类型 2-3种，步数余量 10-20%",
      "boss": "障碍数量 6-10个，类型 当章全部已解锁，步数余量 ≈10%"
    }
  },

