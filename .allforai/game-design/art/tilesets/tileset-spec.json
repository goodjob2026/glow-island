  "applicability": "APPLICABLE",
  "applicability_note": "Glow Island is a casual mobile puzzle game with a match-3 board. The board cells are assembled from repeatable tile icons (puzzle_grid mode). Tiles are static PNG icons arranged in a grid; connectivity is single_tiles because each cell displays exactly one tile icon with no terrain transitions.",

  "tilemap": {
    "mode": "puzzle_grid",
    "projection": "orthographic",
    "tile_size": 128,
    "tile_size_2x": 256,
    "connectivity": "single_tiles",
    "collision_model": "none",
    "bleed_px": 8,
    "effective_draw_area_px": 112,
    "corner_radius_2x": 24,
    "outline_width_px": 2,
    "outline_style": "primary_color_darkened_32pct",
    "paper_texture_overlay_opacity": 0.06,
    "format": "png",
    "atlas_max_px": 2048,
    "atlas_policy": "per_chapter",
    "chapter_atlas_naming": "tiles_ch{N}_atlas",
    "chapter_count": 6,
    "special_blocks_atlas": "special_blocks_atlas"
  },

  "style": {
    "dimension": "2d",
    "render_style": "hand_drawn",
    "style_keywords": ["hand-drawn-watercolor", "soft-rounded-organic", "warm-pastel-palette", "nature-element-tiles"],
    "genre_reference": "Animal Crossing × 日式离岛美学 (Wytchwood水彩质感)",
    "prohibited_styles": ["pixel_art", "hyper_realistic_3d", "neon_cyberpunk_palette", "metallic_chrome_gradients", "pure_black_000000", "sharp_corner_geometric_ui"],
    "outline_color_rule": "darken primary color by 32%, never use pure black #000000",
    "shadow_policy": "no shadows crossing tile boundaries; soft inner shadow only within bleed zone",
    "readability_rule": "silhouette must be readable at 32×32px scale"
  },

