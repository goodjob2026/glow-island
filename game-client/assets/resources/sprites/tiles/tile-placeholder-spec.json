{
  "_meta": {
    "project": "Glow Island",
    "version": "1.0",
    "created_at": "2026-05-07",
    "description": "Complete placeholder specification for all 20 tile types. Each tile is 128×128px @2x with 4px bleed. Placeholder colors are derived from art-tokens chapter palettes.",
    "size_note": "Canvas: 128×128px @2x. Visible draw area: 120×120px (4px bleed each side). Corner radius: 16px."
  },
  "global_spec": {
    "canvas_size_2x": { "w": 128, "h": 128 },
    "canvas_size_1x": { "w": 64, "h": 64 },
    "bleed_px": 4,
    "draw_area_2x": { "w": 120, "h": 120 },
    "corner_radius_2x": 16,
    "corner_radius_1x": 8,
    "color_depth": "RGBA 32-bit",
    "export_format": "PNG-24 transparent background",
    "atlas_max_size": "2048×2048",
    "shadow_baked": "0 3px 0 rgba(0,0,0,0.12)"
  },
  "states_spec": {
    "normal": {
      "key": "normal",
      "filename_suffix": "_normal@2x.png",
      "description": "Default static single-frame PNG. Shadow baked: rgba(0,0,0,0.12) offset 0,3px.",
      "brightness_modifier": 1.0,
      "inner_glow": null
    },
    "highlighted": {
      "key": "highlighted",
      "filename_suffix": "_highlighted@2x.png",
      "description": "Connection highlight state. Brightness +20%, inner glow rgba(255,255,255,0.35). Can be achieved via runtime shader from Normal frame.",
      "brightness_modifier": 1.2,
      "inner_glow": "rgba(255,255,255,0.35)",
      "scale_hint": 1.05
    },
    "disappearing": {
      "key": "disappearing",
      "filename_suffix": "_disappear_{frame:02d}@2x.png",
      "description": "12-frame sequence at 30fps (0.4s total). Scale peaks at 1.08 on frame 4, then shrinks with particle scatter. Final frame fully transparent.",
      "frame_count": 12,
      "fps": 30,
      "duration_seconds": 0.4,
      "peak_frame": 4,
      "peak_scale": 1.08,
      "canvas_size_2x": { "w": 160, "h": 160 }
    },
    "special": {
      "key": "special",
      "description": "Spine skeleton animation for the 4 special tile types (Bomb/Lightning/Rainbow/Glow). Includes idle (loop 2-3s) and activate (one-shot 0.5-1.0s).",
      "animations": ["idle", "activate"],
      "export_files": [".skel", ".atlas", ".png"]
    }
  },
