  "_stages": [
    {
      "id": "stage1_color_restore",
      "label": "Stage 1: Gray to Color",
      "start": 0,
      "end": 1.0,
      "description": "Fade in from desaturated gray to full color. ColorOverlay transitions from gray (180,180,180) to white (255,255,255) revealing the colorized sprite beneath."
    },
    {
      "id": "stage2_details_appear",
      "label": "Stage 2: Details / Particles Appear",
      "start": 1.0,
      "end": 2.5,
      "description": "DetailLayer fades in (opacity 0→255). Particle systems triggered via onRestoreStageStart event. Props and foliage details become visible."
    },
    {
      "id": "stage3_glow_pulse",
      "label": "Stage 3: Glow Pulse",
      "start": 2.5,
      "end": 4.0,
      "description": "GlowLayer pulses in and out (opacity 0→255→0) with a scale bump (1.0→1.08→1.0) creating a bloom/glow effect over the restored area."
    },
    {
      "id": "stage4_settle",
      "label": "Stage 4: Settle to Final State",
      "start": 4.0,
      "end": 5.0,
      "description": "Root node scale returns to 1.0, all layers settle. Root scale has one final micro-pulse (1.0→1.05→1.0) then holds. Animation ends in final restored state."
    }
  ],
  "_animationSettings": {
    "loop": false,
    "playOnLoad": false
  },
  "_meta": {
    "source": "art-tokens.json",
    "token_ref": {
