{
  "__version__": "1.3.9",
  "textureCompressConfig": {
    "genMipmaps": false
  },
  "options": {
    "packages": {
      "ios": {
        "packageName": "com.glowisland.app",
        "orientation": "portrait"
      }
    }
  },
  "packages": {
    "ios": {
      "packageName": "com.glowisland.app",
      "orientation": "portrait"
    }
  },
  "BuildTaskManager": {
    "queue": [
      {
        "id": "ios",
        "state": "success",
        "progress": 1,
        "options": {
          "platform": "ios",
          "buildPath": "build",
          "debug": false,
          "md5Cache": false,
          "packages": {
            "ios": {
              "packageName": "com.glowisland.app",
              "orientation": {
                "portrait": true,
                "landscapeLeft": false,
                "landscapeRight": false
              },
              "skipUpdateXcodeProject": false
            },
            "native": {
              "template": "link",
              "polyfills": {
                "asyncFunctions": true
              }
            }
          }
        }
      }
    ]
  }
}